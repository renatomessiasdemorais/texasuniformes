# Sanity — crie o projeto com `npx sanity login` + `npx sanity init` (ver README)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Necessário apenas para rodar scripts/seed-sanity.mjs (token de escrita, gerado em manage.sanity.io)
SANITY_API_WRITE_TOKEN=

# Segredo compartilhado com o webhook do Sanity (API > Webhooks) para revalidar
# o site em segundos quando algo é publicado no Studio — ver README
SANITY_REVALIDATE_SECRET=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
LEAD_EMAIL_TO=contato@texasuniformes.com.br
LEAD_EMAIL_FROM="Texas Uniformes <onboarding@resend.dev>"

# URL pública do site em produção (usada em metadata, sitemap.xml e og:url)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 (opcional — deixe em branco para desativar)
NEXT_PUBLIC_GA_ID=
